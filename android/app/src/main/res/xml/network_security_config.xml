<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- SECURITY IMPROVEMENT: Default secure configuration -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
    
    <!-- Development and testing domains (cleartext allowed) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>
    
    <!-- API server configuration - prefer HTTPS, allow HTTP as temporary fallback -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">122.199.183.213</domain>
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </domain-config>
    
    <!-- Production security configuration (stricter) -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="false">api.example.com</domain>
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </domain-config>
    
    <!-- Debug overrides for development -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </debug-overrides>
</network-security-config>